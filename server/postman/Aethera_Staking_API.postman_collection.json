              "name": "500 Project Not Approved",
              "status": "Internal Server Error",
              "code": 500,
              "body": "{\n  \"success\": false,\n  \"error\": \"Move abort in state::create_project_vault: E_PROJECT_NOT_APPROVED\"\n}"
