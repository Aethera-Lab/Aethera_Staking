# Research Pipeline Configuration

# Server
PORT=4100

# Optional: NewsAPI key for broader coverage (https://newsapi.org)
NEWS_API_KEY=

# Optional: Google Custom Search API (for deeper web scraping)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Scraping settings
SCRAPE_INTERVAL_HOURS=6
MAX_CONCURRENT_REQUESTS=3
REQUEST_DELAY_MS=2000

# Database
DB_PATH=./data/research.db
