{
  "name": "aethera-research-pipeline",
  "version": "1.0.0",
  "description": "Research pipeline for scraping and indexing global tokenization updates — solar energy, RWA, carbon credits, and more",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/cli.ts scrape",
    "search": "tsx src/cli.ts search",
    "report": "tsx src/cli.ts report",
    "serve": "tsx src/api/server.ts",
    "export": "tsx src/cli.ts export",
    "scrape:cron": "tsx src/cli.ts scrape --all"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "rss-parser": "^3.13.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "p-limit": "^6.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
